# Environment Variables for CodeExplain AI

# Explanation mode (developer | beginner | fun:pirate | fun:shakespeare | fun:eli5)
CODEEXPLAIN_DEFAULT_MODE=developer

# Default output format (json | html | markdown | cli)
CODEEXPLAIN_OUTPUT_FORMAT=cli

# API server host and port
CODEEXPLAIN_API_HOST=127.0.0.1
CODEEXPLAIN_API_PORT=8000

# Log level (DEBUG | INFO | WARNING | ERROR)
CODEEXPLAIN_LOG_LEVEL=INFO

# Max file size (in KB) for analysis
CODEEXPLAIN_MAX_FILE_SIZE_KB=500
